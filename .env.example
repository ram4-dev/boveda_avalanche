# Bóveda Fuji deployment example
# Copy to .env.local or export these in your shell. Never commit real secrets.

# Required for forge script --broadcast. Keep the real value out of git/logs.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: existing USDC/proceeds token. If omitted/zero, Deploy.s.sol deploys a mock USDC.
USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Chainlink-compatible oracle setup.
# Use verified Avalanche Fuji token/feed addresses from Chainlink docs before broadcast.
CHAINLINK_MAX_STALENESS_SECONDS=86400
COLLATERAL_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
COLLATERAL_USD_FEED_ADDRESS=0x0000000000000000000000000000000000000000

# Backend runtime
PORT=3000
HOST=0.0.0.0

# Wavy Node risk adapter mode: mock (default) or real
WAVYNODE_MODE=mock

# Real Wavy Node adapter settings (required only when WAVYNODE_MODE=real)
# scan-risk polling is short-bounded for demo responsiveness
WAVYNODE_BASE_URL=https://api.wavynode.com/v1
WAVYNODE_API_KEY=ApiKey wavy_your_api_key_here
WAVYNODE_PROJECT_ID=your_project_id
WAVYNODE_CHAIN_ID=43114
WAVYNODE_RISK_TTL_SECONDS=900
WAVYNODE_SCAN_RETRIES=2
WAVYNODE_SCAN_RETRY_DELAY_MS=750

# Demo-only fallback. Keep fail for production/compliance.
# Set to pass only when Wavy fails no-history investigations during a controlled demo.
WAVYNODE_NO_HISTORY_POLICY=fail
